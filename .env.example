# -----------------------------
# Server
# -----------------------------
PORT=3001
SCAN_INTERVAL_MS=15000

# DingTalk (optional)
WEBHOOK_URL=
WEBHOOK_URL_TOKEN=

# MySQL (server)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=stock_monitor
DB_USER=root
DB_PASSWORD=

# -----------------------------
# Python agents service
# -----------------------------
AGENTS_BASE_URL=http://127.0.0.1:8009
AGENTS_PORT=8009
AGENTS_HISTORY_LIMIT=12
REDIS_URL=

# LLM (OpenAI-compatible)
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen3-max

# Optional: enable PostgreSQL-backed memory for agents
# When enabled, prefer setting AGENTS_POSTGRES_URL (recommended).
AGENTS_USE_POSTGRES=
AGENTS_POSTGRES_URL=
PG_HOST=
PG_PORT=5432
PG_NAME=
PG_USER=
PG_PASSWORD=
