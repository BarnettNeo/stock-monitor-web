# .env.production
# 请将这里的占位符替换为您的生产环境实际配置

# Webhook and scan interval
WEBHOOK_URL = 'https://oapi.dingtalk.com/robot/send'
WEBHOOK_URL_TOKEN = 'your_production_webhook_token'
SCAN_INTERVAL_MS = 15000
PORT=3001 # 后端服务在服务器上运行的端口

# Python agents service
AGENTS_BASE_URL=http://127.0.0.1:8009
AGENTS_PORT=8009

# LLM (OpenAI-compatible) for agents
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-659401d590714ce3a8afd39a8ede4acd
LLM_MODEL=qwen-max

# Optional memory for agents
REDIS_URL=
AGENTS_HISTORY_LIMIT=12

# --- 生产环境 MySQL 配置 ---
# 如果 MySQL 和后端服务在同一台服务器上，通常用 127.0.0.1
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=stock_monitor
DB_USER=root # 生产环境数据库用户名
DB_PASSWORD=NIANpeng1998! # 生产环境数据库密码

# --- 生产环境 Celery 配置 ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2